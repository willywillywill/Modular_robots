<launch>
    <arg name="com_port" default="/dev/ttyUSB1" />

    <include file="$(find rplidar_ros)/launch/rplidar_a1.launch" />

    <node pkg="tf2_ros"
          type="static_transform_publisher"
          name="laser_tf"
          args="0 0 0 0 0 0 base_link laser"
          output="screen" />
          
    <node 
        name="odom_publisher"
        pkg="bot_move"
        type="odom_pub.py"
        output="screen">
        <param name="com_port" value="$(arg com_port)" />
        <param name="vx_deadband" value="0.05" />
        <param name="vy_deadband" value="0.05" />
        <param name="wz_deadband" value="0.05" />
    </node>

    <node pkg="hector_mapping"
          type="hector_mapping"
          name="hector_mapping"
          output="screen">
        <param name="map_frame" value="map" />
        <param name="odom_frame" value="odom" />
        <param name="base_frame" value="base_link" />
        <param name="pub_map_odom_transform" value="true" />
        <param name="scan_topic" value="scan" />
        <param name="transform_tolerance" value="1.0" />
    </node>
    <!--
    <node
        pkg="teleop_twist_keyboard"
        type="teleop_twist_keyboard.py"
        name="teleop_keyboard"
        output="screen">
        <remap from="/cmd_vel" to="/move_topic"/>
    </node>
    -->

    <node name="move_subscriber"
          pkg="bot_move"
          type="move_sub.py"
          output="screen">
        <param name="com_port" value="$(arg com_port)" />
    </node>

    <node pkg="move_base"
          type="move_base"
          name="move_base"
          output="screen">

        <remap from="cmd_vel" to="/move_topic" />

        <rosparam file="$(find bot_move)/config/move_base/costmap_common_params.yaml"
                  command="load"
                  ns="global_costmap" />

        <rosparam file="$(find bot_move)/config/move_base/costmap_common_params.yaml"
                  command="load"
                  ns="local_costmap" />

        <rosparam file="$(find bot_move)/config/move_base/global_costmap_params.yaml"
                  command="load" />

        <rosparam file="$(find bot_move)/config/move_base/local_costmap_params.yaml"
                  command="load" />

        <rosparam file="$(find bot_move)/config/move_base/move_base_params.yaml"
                  command="load" />

        <rosparam file="$(find bot_move)/config/move_base/dwa_local_planner_params.yaml"
                  command="load" />
    </node>


    <node pkg="rviz"
          type="rviz"
          name="rviz"
          args="-d $(find bot_move)/rviz/view.rviz"
          output="screen" />
</launch>