<launch>
    <node pkg="move_base" type="move_base" name="move_base" output="screen">
        <rosparam file="$(find bot_move)/config/costmap_common.yaml"
                  command="load"
                  ns="global_costmap"/>
        <rosparam file="$(find bot_move)/config/costmap_common.yaml"
                  command="load"
                  ns="local_costmap"/>

        <rosparam file="$(find bot_move)/config/global_costmap.yaml"
                  command="load"
                  ns="global_costmap"/>
        <rosparam file="$(find bot_move)/config/local_costmap.yaml"
                  command="load"
                  ns="local_costmap"/>
        <rosparam file="$(find bot_move)/config/dwa_local_planner.yaml"
                  command="load"/>

        <remap from="cmd_vel" to="/move_topic"/>
    </node>
</launch>
